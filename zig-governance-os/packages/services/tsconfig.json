{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "@zig/types": ["../types/src/index.ts"],
      "@zig/data-access": ["../data-access/src/index.ts"],
      "@zig/billing": ["../billing/src/index.ts"],
      "@zig/automation": ["../automation/src/index.ts"],
      "@zig/imports": ["../imports/src/index.ts"],
      "@zig/exports": ["../exports/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
